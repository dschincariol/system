#!/usr/bin/env bash
# trading-ctl — desktop start/stop control for the trading system.
#
# Run AS the desktop user 'david'. It:
#   * ensures the docker data layer (timescaledb/redis/minio) is up AND ready,
#   * decommissions any stale competing engine containers,
#   * starts/stops the systemd units (trading-engine + trading-operator) via
#     polkit (no sudo) — see /etc/polkit-1/rules.d/49-trading-system.rules,
#   * health-gates on the real readiness endpoint (/api/health), not a bare socket,
#   * opens the dashboard in a browser (token-bootstrapped).
#
# It deliberately performs a GRACEFUL stop (systemctl stop) and leaves the data
# layer running. It NEVER triggers the kill-switch / emergency-stop — that stays a
# separate, deliberate action in the operator UI.
set -uo pipefail

# --- configuration -----------------------------------------------------------
ENGINE_UNIT="trading-engine.service"
OPERATOR_UNIT="trading-operator.service"
UNITS=("$ENGINE_UNIT" "$OPERATOR_UNIT")
DATA_CONTAINERS=(trading-timescaledb trading-redis trading-minio)
HEALTHCHECK_CONTAINERS=(trading-timescaledb trading-redis)   # minio has no docker healthcheck
STALE_CONTAINERS=(trading-runtime trading-operator)          # old compose engine/operator — must not coexist
DASH_PORT=8000
OPER_PORT=4001
HEALTH_URL="http://127.0.0.1:${DASH_PORT}/api/health"
CRED_SHOW="/opt/trading/bin/trading-cred-show"
DEP_WAIT_S=90
HEALTH_WAIT_S=120
UNIT_WAIT_S=120

LAN_IP="$(hostname -I 2>/dev/null | tr ' ' '\n' | grep -E '^(192\.168|10\.|172\.(1[6-9]|2[0-9]|3[01]))\.' | grep -vE '^(172\.1[78]\.|172\.17\.)' | head -1)"

note() { printf '\033[1;36m[trading]\033[0m %s\n' "$*"; }
ok()   { printf '\033[1;32m[ ok ]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[warn]\033[0m %s\n' "$*"; }
err()  { printf '\033[1;31m[fail]\033[0m %s\n' "$*" >&2; }
desktop_notify() { command -v notify-send >/dev/null 2>&1 && notify-send -a "Trading System" "$1" "${2:-}" >/dev/null 2>&1 || true; }

require_tools() {
  local missing=()
  for t in docker systemctl curl; do command -v "$t" >/dev/null 2>&1 || missing+=("$t"); done
  if ((${#missing[@]})); then err "missing required tools: ${missing[*]}"; exit 1; fi
}

# --- docker data layer -------------------------------------------------------
docker_up() { docker info >/dev/null 2>&1; }

container_state() { docker inspect -f '{{.State.Status}}' "$1" 2>/dev/null || echo absent; }
container_health() { docker inspect -f '{{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}' "$1" 2>/dev/null || echo none; }

ensure_data_layer() {
  if ! docker_up; then
    err "docker daemon is not running — start it with: sudo systemctl start docker"
    return 1
  fi
  for c in "${DATA_CONTAINERS[@]}"; do
    local st; st="$(container_state "$c")"
    case "$st" in
      running) : ;;
      absent)  err "data container '$c' does not exist — bring the stack up once with:"
               err "  docker compose -f /opt/trading/app/deploy/compose/docker-compose.external-services.yml up -d"
               return 1 ;;
      *)       note "starting data container $c (was: $st)"; docker start "$c" >/dev/null 2>&1 || { err "could not start $c"; return 1; } ;;
    esac
  done
  # wait for healthchecks to report healthy (timescaledb + redis define them)
  local deadline=$((SECONDS + DEP_WAIT_S))
  for c in "${HEALTHCHECK_CONTAINERS[@]}"; do
    while :; do
      local h; h="$(container_health "$c")"
      [[ "$h" == "healthy" || "$h" == "none" ]] && break
      if ((SECONDS >= deadline)); then err "data container $c not healthy after ${DEP_WAIT_S}s (health=$h)"; return 1; fi
      sleep 2
    done
  done
  # authenticated-readiness belt-and-suspenders for Postgres (closes the TCP-open-but-not-query-ready race)
  if command -v pg_isready >/dev/null 2>&1; then
    while :; do
      pg_isready -h 127.0.0.1 -p 5432 -U trading -d trading -q && break
      if ((SECONDS >= deadline)); then warn "pg_isready did not confirm within ${DEP_WAIT_S}s; continuing (container reports healthy)"; break; fi
      sleep 2
    done
  fi
  ok "data layer ready (timescaledb / redis / minio)"
}

decommission_stale() {
  for c in "${STALE_CONTAINERS[@]}"; do
    local st; st="$(container_state "$c")"
    [[ "$st" == "absent" ]] && continue
    warn "decommissioning stale competing container '$c' (state=$st) so it can't grab :$DASH_PORT"
    docker update --restart=no "$c" >/dev/null 2>&1 || true
    docker rm -f "$c" >/dev/null 2>&1 || true
  done
}

port_owner() { ss -ltnHp "sport = :$1" 2>/dev/null | sed -E 's/.*users:\(\("([^"]+)".*/\1/' | head -1; }

# --- systemd units (via polkit, no sudo) ------------------------------------
is_active() { [[ "$(systemctl is-active "$1" 2>/dev/null)" == "active" ]]; }

start_unit() {
  local u="$1"
  if is_active "$u"; then ok "$u already active"; return 0; fi
  note "starting $u"
  if ! systemctl --no-block start "$u" 2>/tmp/.trading-ctl.err; then
    err "could not start $u: $(cat /tmp/.trading-ctl.err 2>/dev/null)"
    err "(polkit denied? confirm /etc/polkit-1/rules.d/49-trading-system.rules is installed)"
    return 1
  fi
  # --no-block returns on enqueue; verify the unit actually reaches active
  local deadline=$((SECONDS + UNIT_WAIT_S))
  while :; do
    local s; s="$(systemctl is-active "$u" 2>/dev/null)"
    [[ "$s" == "active" ]] && { ok "$u active"; return 0; }
    if [[ "$s" == "failed" ]] || ((SECONDS >= deadline)); then
      err "$u did not reach active (state=$s). Recent log:"
      systemctl --no-pager --lines=20 status "$u" 2>/dev/null | sed 's/^/    /' || true
      return 1
    fi
    sleep 2
  done
}

stop_unit() {
  local u="$1"
  if ! is_active "$u"; then ok "$u already stopped"; return 0; fi
  note "stopping $u (graceful)"
  systemctl --no-block stop "$u" 2>/tmp/.trading-ctl.err || { err "could not stop $u: $(cat /tmp/.trading-ctl.err 2>/dev/null)"; return 1; }
  local deadline=$((SECONDS + UNIT_WAIT_S))
  while is_active "$u"; do
    if ((SECONDS >= deadline)); then warn "$u still stopping after ${UNIT_WAIT_S}s"; return 0; fi
    sleep 2
  done
  ok "$u stopped"
}

# --- health ------------------------------------------------------------------
fetch_token() {
  # Decrypt the dashboard API token via the narrowly-scoped pkexec helper.
  [[ -x "$CRED_SHOW" ]] || { command -v pkexec >/dev/null 2>&1 || return 1; }
  pkexec "$CRED_SHOW" 2>/dev/null | tr -d '\r\n'
}

wait_health() {
  note "waiting for dashboard readiness ($HEALTH_URL)"
  local deadline=$((SECONDS + HEALTH_WAIT_S)) good=0 body
  while :; do
    body="$(curl -fsS -m 4 "$HEALTH_URL" 2>/dev/null)"
    if [[ -n "$body" ]] && printf '%s' "$body" | grep -qiE '"ok"[[:space:]]*:[[:space:]]*true'; then
      good=$((good + 1))
      ((good >= 2)) && { ok "dashboard healthy on :$DASH_PORT"; return 0; }
    else
      good=0
    fi
    if ((SECONDS >= deadline)); then
      err "dashboard did not report healthy within ${HEALTH_WAIT_S}s"
      err "engine log tail:"; tail -n 25 /var/lib/trading/logs/engine.log 2>/dev/null | sed 's/^/    /' || true
      return 1
    fi
    sleep 3
  done
}

open_dashboard() {
  local token="${1:-}" local_url lan_url qs=""
  [[ -n "$token" ]] && qs="?token=${token}"
  local_url="http://127.0.0.1:${DASH_PORT}/ui/dashboard.html${qs}"
  note "dashboard (this machine): ${local_url}"
  if [[ -n "$LAN_IP" ]]; then
    lan_url="http://${LAN_IP}:${DASH_PORT}/ui/dashboard.html${qs}"
    note "dashboard (LAN, e.g. phone/laptop): ${lan_url}"
    [[ -z "$token" ]] && warn "no token in URL — append ?token=<TOKEN> once to log in (run: trading-ctl token)"
  fi
  command -v xdg-open >/dev/null 2>&1 && xdg-open "$local_url" >/dev/null 2>&1 &
}

# --- subcommands -------------------------------------------------------------
cmd_start() {
  require_tools
  if [[ -n "$(port_owner "$DASH_PORT")" ]] && ! is_active "$ENGINE_UNIT"; then
    err "port :$DASH_PORT is already held by '$(port_owner "$DASH_PORT")' (a non-systemd process). Resolve before starting."
    exit 1
  fi
  ensure_data_layer || { desktop_notify "Start failed" "data layer not ready"; exit 1; }
  decommission_stale
  start_unit "$OPERATOR_UNIT" || { desktop_notify "Start failed" "operator did not start"; exit 1; }
  start_unit "$ENGINE_UNIT"   || { desktop_notify "Start failed" "engine did not start"; exit 1; }
  wait_health                 || { desktop_notify "Start degraded" "dashboard not healthy"; exit 1; }
  local token; token="$(fetch_token || true)"
  open_dashboard "$token"
  ok "Trading system started."
  desktop_notify "Trading system started" "Dashboard on :$DASH_PORT"
}

cmd_stop() {
  require_tools
  stop_unit "$ENGINE_UNIT"
  stop_unit "$OPERATOR_UNIT"
  note "data layer (timescaledb/redis/minio) left running by design."
  ok "Trading system stopped (graceful; no kill-switch)."
  desktop_notify "Trading system stopped" "Data layer left running"
  cmd_status
}

cmd_restart() { cmd_stop; cmd_start; }

port_line() {
  local port="$1" label="$2" owner state
  owner="$(port_owner "$port")"
  if [[ -n "$owner" ]]; then state="LISTEN (${owner})"; else state="(none)"; fi
  printf '  %-10s :%s  %s\n' "$label" "$port" "$state"
}

cmd_status() {
  printf '%s\n' '' '--- units ---'
  for u in "${UNITS[@]}"; do printf '  %-26s %s\n' "$u" "$(systemctl is-active "$u" 2>/dev/null)"; done
  printf '%s\n' '--- data containers ---'
  for c in "${DATA_CONTAINERS[@]}"; do printf '  %-22s state=%s health=%s\n' "$c" "$(container_state "$c")" "$(container_health "$c")"; done
  printf '%s\n' '--- ports ---'
  port_line "$DASH_PORT" dashboard
  port_line "$OPER_PORT" operator
  printf '\n'
}

cmd_token() {
  local t; t="$(fetch_token || true)"
  if [[ -z "$t" ]]; then err "could not retrieve dashboard token (pkexec/cred helper unavailable)"; exit 1; fi
  printf 'Dashboard API token: %s\n' "$t"
  [[ -n "$LAN_IP" ]] && printf 'LAN login URL: http://%s:%s/ui/dashboard.html?token=%s\n' "$LAN_IP" "$DASH_PORT" "$t"
}

cmd_open() { local t; t="$(fetch_token || true)"; open_dashboard "$t"; }

case "${1:-status}" in
  start)   cmd_start ;;
  stop)    cmd_stop ;;
  restart) cmd_restart ;;
  status)  cmd_status ;;
  token)   cmd_token ;;
  open)    cmd_open ;;
  *) echo "usage: trading-ctl {start|stop|restart|status|token|open}"; exit 2 ;;
esac
