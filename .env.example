CONGRESSIONAL_HOUSE_SOURCE_URL=https://house-stock-watcher-data.s3-us-west-2.amazonaws.com/data/all_transactions.json

# Execution realism finishers
PORTFOLIO_BACKTEST_USE_EXEC_COSTS=0
