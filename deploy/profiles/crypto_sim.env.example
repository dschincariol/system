# Crypto data-only sim/paper profile.
# This enables CCXT spot/OHLCV polling and crypto funding ingestion only.
# It does not enable live execution, live broker routing, or live order mutation.

ENGINE_MODE=sim
EXECUTION_MODE=sim
BROKER=sim
BROKER_NAME=sim
DISABLE_LIVE_EXECUTION=1
KILL_SWITCH_GLOBAL=1
CRYPTO_LIVE_TRADING_ENABLED=0
CRYPTO_NOTIONAL_CAP_USD=10000

CCXT_ENABLED=1
INGEST_CRYPTO_FUNDING_ENABLED=1
USE_FUNDING_FEATURES=1

# Empty means the funding poller auto-discovers active crypto symbols from the
# symbols table when available. Override with entries such as:
# BTC|binanceusdm|BTC/USDT:USDT|BTC/USDT,ETH|binanceusdm|ETH/USDT:USDT|ETH/USDT
CRYPTO_PERP_MARKETS=

CCXT_EXCHANGE_ID=kraken
CCXT_FUNDING_EXCHANGE_ID=binanceusdm
CRYPTO_FUNDING_POLL_SECONDS=3600
CRYPTO_FUNDING_ALIGN_TO_SETTLEMENT_MARKS=1
