# Container images: set these to your approved tags.
TIMESCALE_IMAGE=
REDIS_IMAGE=
MINIO_IMAGE=
MINIO_CLIENT_IMAGE=
PYTHON_RUNTIME_IMAGE=python:3.11-slim
NODE_RUNTIME_IMAGE=node:20-bookworm-slim
APP_RUNTIME_IMAGE=trading-system/runtime:local
APP_OPERATOR_IMAGE=trading-system/operator:local
TRADING_REQUIREMENTS_FILE=requirements.txt
TRADING_ACCELERATION_PROFILE=cpu
# ROCm overlay defaults for Strix Halo on bart; override from `getent group`.
TRADING_RENDER_GID=991
TRADING_VIDEO_GID=44

# Production resource isolation defaults for a 16-core / 32-thread host with
# 123 GiB RAM. Total container limits reserve about 7 logical CPUs and 27 GiB
# RAM for the OS, Docker, diagnostics, tests, IDEs, and emergency shell work.
PREFLIGHT_CHECK_RESOURCE_LIMITS=1
TRADING_RESOURCE_HOST_CPUS=32
TRADING_RESOURCE_HOST_MEMORY=123g
TRADING_RESOURCE_MIN_HEADROOM_CPUS=6
TRADING_RESOURCE_MIN_HEADROOM_MEMORY=24g
PREFLIGHT_REQUIRE_MEMORY_PRESSURE_POLICY=1
TRADING_SWAPPINESS=10
TRADING_ZRAM_SIZE_GIB=32
TRADING_ZRAM_PRIORITY=100
TRADING_SWAPFILE_SIZE_GIB=16
TRADING_SWAPFILE_PRIORITY=10
TRADING_SWAPFILE_PATH=/swapfile-trading
TRADING_ZFS_ARC_MAX_GIB=48

RUNTIME_CPUS=12
RUNTIME_MEM_LIMIT=48g
RUNTIME_MEMSWAP_LIMIT=48g
RUNTIME_SHM_SIZE=8g
TRADING_CPU_THREAD_POLICY=auto
TRADING_CPU_THREADS_PER_PROCESS=
TRADING_TORCH_INTEROP_THREADS_PER_PROCESS=
TRADING_CPU_THREAD_PROCESS_COUNT=
TRADING_CPU_THREAD_TOTAL=
TRADING_DEFAULT_INGESTION_CHILD_COUNT=12
RUNTIME_OMP_NUM_THREADS=8
RUNTIME_MKL_NUM_THREADS=8
RUNTIME_OPENBLAS_NUM_THREADS=8
RUNTIME_NUMEXPR_NUM_THREADS=8
RUNTIME_NUMEXPR_MAX_THREADS=8
RUNTIME_VECLIB_MAXIMUM_THREADS=8
TORCH_CPU_THREADS=8
TORCH_INTEROP_THREADS=4

TIMESCALE_CPUS=8
TIMESCALE_MEM_LIMIT=32g
TIMESCALE_MEMSWAP_LIMIT=32g
TIMESCALE_SHM_SIZE=2g
# These TIMESCALE_* values are the single source of truth for Docker Postgres
# tuning. docker-compose.external-services.yml passes them to postgres -c, and
# prod_preflight.py validates the same values from the runtime container.
PREFLIGHT_REQUIRE_DOCKER_POSTGRES_TUNING=1
PREFLIGHT_REQUIRE_DOCKER_RUNTIME_EVIDENCE=1
PREFLIGHT_DOCKER_INSPECT_JSON=/var/backups/trading/evidence/docker_runtime_inspect.json
PREFLIGHT_REDIS_CONFIG_EVIDENCE=/var/backups/trading/evidence/redis_config_get.txt
PREFLIGHT_POSTGRES_SETTINGS_JSON=/var/backups/trading/evidence/postgres_pg_settings.json
TIMESCALE_MAX_CONNECTIONS=100
TIMESCALE_SHARED_BUFFERS=8GB
TIMESCALE_EFFECTIVE_CACHE_SIZE=22GB
TIMESCALE_WORK_MEM=48MB
TIMESCALE_WORK_MEM_ACTIVE_CONNECTIONS=64
TIMESCALE_WORK_MEM_NODE_FACTOR=2
TIMESCALE_MAINTENANCE_WORK_MEM=2GB
TIMESCALE_AUTOVACUUM_WORK_MEM=512MB
TIMESCALE_WAL_BUFFERS=64MB
TIMESCALE_MIN_WAL_SIZE=4GB
TIMESCALE_MAX_WAL_SIZE=16GB
TIMESCALE_WAL_KEEP_SIZE=1GB
TIMESCALE_MAX_SLOT_WAL_KEEP_SIZE=8GB
TIMESCALE_WAL_DISK_BUDGET=40g
TIMESCALE_ARCHIVE_MODE=on
TIMESCALE_ARCHIVE_TIMEOUT=60s
TIMESCALE_CHECKPOINT_TIMEOUT=15min
TIMESCALE_CHECKPOINT_COMPLETION_TARGET=0.9
TIMESCALE_MAX_WORKER_PROCESSES=16
TIMESCALE_MAX_PARALLEL_WORKERS=8
TIMESCALE_MAX_PARALLEL_WORKERS_PER_GATHER=4
TIMESCALE_MAX_PARALLEL_MAINTENANCE_WORKERS=4
TIMESCALE_TIMESCALEDB_MAX_BACKGROUND_WORKERS=8
TIMESCALE_AUTOVACUUM=on
TIMESCALE_AUTOVACUUM_MAX_WORKERS=4
TIMESCALE_AUTOVACUUM_NAPTIME=10s
TIMESCALE_AUTOVACUUM_VACUUM_COST_LIMIT=4000
TIMESCALE_AUTOVACUUM_VACUUM_COST_DELAY=2ms
TIMESCALE_RANDOM_PAGE_COST=1.1
TIMESCALE_EFFECTIVE_IO_CONCURRENCY=200
TIMESCALE_MAINTENANCE_IO_CONCURRENCY=200

REDIS_CPUS=2
REDIS_MEM_LIMIT=8g
REDIS_MEMSWAP_LIMIT=8g
REDIS_MAXMEMORY=6gb
REDIS_MAXMEMORY_POLICY=allkeys-lru

MINIO_CPUS=2
MINIO_MEM_LIMIT=6g
MINIO_MEMSWAP_LIMIT=6g

OPERATOR_CPUS=1
OPERATOR_MEM_LIMIT=2g
OPERATOR_MEMSWAP_LIMIT=2g

# Docker stdout/stderr retention for every compose service. File logs under
# /app/logs are separately rotated by deploy/logrotate/trading-system.
DOCKER_LOG_DRIVER=local
DOCKER_LOG_MAX_SIZE=50m
DOCKER_LOG_MAX_FILE=5

# External dependency credentials and ports. Production uses files/providers;
# do not paste secret values into repo-local .env files.
TIMESCALE_DB=trading
TIMESCALE_USER=trading
TIMESCALE_PASSWORD_FILE=../../data/secrets/timescale_password
TIMESCALE_DANGEROUS_PUBLIC_BIND_HOST=127.0.0.1
TIMESCALE_PORT=5432
TIMESCALE_ALLOW_DANGEROUS_PUBLIC_BIND=0
PREFLIGHT_REQUIRE_ZFS_STORAGE=1
PREFLIGHT_STORAGE_REQUIRE_VISIBLE_HOST_PATHS=1
TRADING_ZFS_ROOT=/zpool
# 3-NVMe layout: /zpool remains OS/backups, while /dbpool and /auxpool
# are separate ZFS pools for live database and rebuildable aux/runtime state.
TRADING_ALLOWED_STORAGE_PREFIXES=/zpool,/dbpool,/auxpool,/var/backups/trading
TRADING_ALLOWED_STORAGE_FS_TYPES=zfs
TRADING_FORBIDDEN_STORAGE_PREFIXES=/var/lib/docker,/var/lib/containerd
# Live Timescale PGDATA and pg_wal bind to the Samsung dbpool.
TRADING_TIMESCALE_DATA=/dbpool/trading/timescaledb/data
# Redis, MinIO, runtime logs/data, artifact caches, training datasets, and
# offline/training scratch bind to the Kingston auxpool.
TRADING_REDIS_DATA=/auxpool/trading/redis
TRADING_MINIO_DATA=/auxpool/trading/minio
TRADING_RUNTIME_DATA=/auxpool/trading/runtime/data
TRADING_RUNTIME_LOGS=/auxpool/trading/runtime/logs
TRADING_ARTIFACT_MIRROR=/auxpool/trading/runtime/artifact_mirror
TRADING_TRAINING_DATASETS=/auxpool/trading/runtime/training_datasets
TRADING_OFFLINE_DATA=/auxpool/trading/offline/data
TRADING_OFFLINE_ARTIFACT_MIRROR=/auxpool/trading/offline/artifact_mirror
TRADING_OFFLINE_TRAINING_DATASETS=/auxpool/trading/offline/training_datasets
TRADING_BACKUP_ROOT=/var/backups/trading
TRADING_BACKUP_WAL_DIR=/var/backups/trading/wal
TRADING_WAL_ARCHIVE_SCRIPT=../../ops/backup/wal_archive.sh
TRADING_WAL_ARCHIVE_CATCHUP_SCRIPT=../../ops/backup/wal_archive_catchup.sh
TIMESCALE_ARCHIVE_COMMAND=/opt/trading/ops/backup/wal_archive.sh "%p" "%f"
TRADING_DATA_ROOT=/app/data
DISK_PRESSURE_WARN_FREE_PCT=15
DISK_PRESSURE_WARN_FREE_BYTES=21474836480
DISK_PRESSURE_CRITICAL_FREE_PCT=5
DISK_PRESSURE_CRITICAL_FREE_BYTES=5368709120
PREFLIGHT_REQUIRE_PG_WAL_RISK=1
PREFLIGHT_PG_WAL_WARN_BYTES=30g
PREFLIGHT_PG_WAL_CRITICAL_BYTES=40g
PREFLIGHT_PG_WAL_READY_WARN_COUNT=4
PREFLIGHT_PG_WAL_READY_CRITICAL_COUNT=16
PREFLIGHT_PG_WAL_WARN_FREE_BYTES=21474836480
PREFLIGHT_PG_WAL_CRITICAL_FREE_BYTES=5368709120
BACKUP_ACCOUNTING_DU_TIMEOUT_S=8
# Local base-backup retention is intentionally short for >1.5TB databases on
# the 2.9TiB Crucial backup pool: keep two local base backups plus a WAL PITR
# cushion, and push archival base backups off host through TS_BASE_BACKUP_OFFSITE_CMD.
TS_BACKUP_KEEP_RECENT_COUNT=2
TS_BACKUP_KEEP_DAILY_DAYS=0
TS_BACKUP_KEEP_WEEKLY_DAYS=0
TS_BACKUP_WAL_CUSHION_DAYS=10
TS_BASE_BACKUP_OFFSITE_CMD=
TS_OFFSITE_BACKUP_DEST=

# Bounded ingestion throughput profile for this 32-thread / 123 GiB host.
# Leave TS_PG_POOL_SIZE blank so runtime roles pick application/ingestion/jobs
# defaults; child ingestion jobs get explicit smaller pools to avoid multiplying
# the supervisor-owned ingestion pool across processes.
TS_PG_POOL_PROFILE=
TS_PG_POOL_MIN_SIZE=
TS_PG_POOL_SIZE=
# Production compose enables relaxed durability only for hardcoded refetchable
# price/telemetry write scopes. Valid values: default, relaxed. Invalid values
# fail production preflight, and financial/control writes never receive this tier.
TRADING_REFETCHABLE_PG_DURABILITY_TIER=relaxed
INGESTION_TUNING_PROFILE=host_32t_123g
INGESTION_TUNING_MAX_TOTAL_DB_CONNECTIONS=32
INGESTION_TUNING_MAX_BUFFERED_ROWS=1200000
INGESTION_CHILD_TS_PG_POOL_MIN_SIZE=1
INGESTION_CHILD_TS_PG_POOL_SIZE=3
INGESTION_CHILD_TIMESCALE_POOL_MAX_SIZE=4
INGESTION_CHILD_TIMESCALE_PRICES_POOL_MAX_SIZE=4
TS_REDIS_POOL_SIZE=32
TS_REDIS_CONNECT_TIMEOUT_S=0.25
TS_REDIS_SOCKET_TIMEOUT_S=0.25

REDIS_PASSWORD_FILE=../../data/secrets/redis_password
REDIS_DANGEROUS_PUBLIC_BIND_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_ALLOW_DANGEROUS_PUBLIC_BIND=0

MINIO_ROOT_USER_FILE=../../data/secrets/minio_root_user
MINIO_ROOT_PASSWORD_FILE=../../data/secrets/minio_root_password
MINIO_DANGEROUS_PUBLIC_BIND_HOST=127.0.0.1
MINIO_PORT=9000
MINIO_ALLOW_DANGEROUS_PUBLIC_BIND=0
MINIO_CONSOLE_DANGEROUS_PUBLIC_BIND_HOST=127.0.0.1
MINIO_CONSOLE_PORT=9001
MINIO_CONSOLE_ALLOW_DANGEROUS_PUBLIC_BIND=0
OBJECT_STORE_BUCKET=trading-artifacts
OBJECT_STORE_REGION=

# Application runtime and host-network exposure defaults.
APP_ENV=prod
ENGINE_MODE=safe
EXECUTION_MODE=safe
OPERATOR_MODE=safe
RUNTIME_WORKLOAD_PROFILE=live
PROD_LOCK=1
ALLOW_TRAINING=0
OFFLINE_TRAINING_LIVE_PROFILE_ACK=
OFFLINE_TRAINING_LIVE_PROFILE_OWNER=
OFFLINE_TRAINING_LIVE_PROFILE_REASON=
RESOURCE_SCHEDULER_GLOBAL_MAX=2
RESOURCE_SCHEDULER_EXECUTION_MAX=1
RESOURCE_SCHEDULER_INFERENCE_MAX=1
RESOURCE_SCHEDULER_TRAINING_MAX=1
RESOURCE_SCHEDULER_REPLAY_MAX=1
RESOURCE_SCHEDULER_BACKGROUND_MAX=1
MODEL_TRAIN_N_JOBS=1
MODEL_TRAIN_MAX_N_JOBS=2
LGBM_N_JOBS=1
LGBM_RANKER_N_JOBS=1
XGB_N_JOBS=1
META_LABEL_N_JOBS=1
TSFRESH_N_JOBS=0
TSFRESH_MAX_N_JOBS=1
TSFRESH_SNAPSHOT_SYMBOL_LIMIT=100
TSFRESH_SNAPSHOT_MAX_SYMBOLS=100
TSFRESH_SNAPSHOT_BATCH_SIZE=25
TSFRESH_SNAPSHOT_MAX_BATCH_SIZE=25
TUNE_N_TRIALS=10
TUNE_MAX_N_TRIALS=10
TRADING_IMPORT_SMOKE_IMPORT_JOBS=0
TRADING_IMPORT_SMOKE_TIMEOUT_S=12.0
TRADING_STARTUP_HEALTH_FAIL_OPEN=0
TRADING_STARTUP_HEALTH_ASYNC_BIND=1
TRADING_PUBLIC_NETWORK_EXPOSURE_ACK=
TRADING_PUBLIC_NETWORK_EXPOSURE_OWNER=
TRADING_PUBLIC_NETWORK_EXPOSURE_REASON=
PREFLIGHT_CHECK_NETWORK_LISTENERS=1
DASHBOARD_DANGEROUS_PUBLIC_BIND_HOST=127.0.0.1
DASHBOARD_PUBLIC_PORT=8000
DASHBOARD_ALLOW_DANGEROUS_PUBLIC_BIND=0
DASHBOARD_API_TOKEN_FILE=../../data/secrets/dashboard_api_token
DASHBOARD_API_TOKEN_MIN_LENGTH=16
TS_API_ALLOW_LOCALHOST_MUTATIONS_WITHOUT_TOKEN=0
OPERATOR_API_TOKEN_FILE=../../data/secrets/operator_api_token
# Preferred LAN contract: dashboard :8000 is the only host/LAN entrypoint.
# The operator sidecar is private to the compose network and is reached through
# the authenticated same-origin dashboard bridge at /operator/. Leaving a
# non-empty OPERATOR_PUBLIC_PORT or enabling OPERATOR_ALLOW_DANGEROUS_PUBLIC_BIND
# under OPERATOR_SIDECAR_INTERNAL_ONLY=1 fails production preflight because it
# implies direct exposure that compose does not publish by default.
OPERATOR_SIDECAR_INTERNAL_ONLY=1
OPERATOR_DANGEROUS_PUBLIC_BIND_HOST=127.0.0.1
OPERATOR_PUBLIC_PORT=
OPERATOR_ALLOW_DANGEROUS_PUBLIC_BIND=0
OPERATOR_ALLOWED_ORIGIN=http://127.0.0.1:8000
# Create this host-side secret before starting the stack:
#   install -m 0600 /dev/null ../../data/.data_source_master_key
#   openssl rand -base64 32 > ../../data/.data_source_master_key
DATA_SOURCE_MASTER_KEY_FILE=../../data/.data_source_master_key

# CPU-first dependency and runtime hardware profiles. PyTorch remains on CPU on
# AMD hosts unless a validated accelerator profile, matching dependency profile,
# and explicit device override are set locally.
TRADING_DEPENDENCY_PROFILE=cpu
RUNTIME_HARDWARE_PROFILE=cpu
TORCH_DEVICE=cpu
EMBED_DEVICE=cpu
NLP_DEVICE=cpu
FINBERT_DEVICE=cpu
TS_FOUNDATION_DEVICE=cpu
NVIDIA_TELEMETRY_ENABLED=0
GPU_THROTTLE_ENABLE=0
PINNED_ENABLE=0
PINNED_PREFETCH=0
TORCH_ALLOW_TF32=0
CUDNN_ALLOW_TF32=0
CUDNN_BENCHMARK=0

# Market data provider bootstrap. Leave disabled for first safe infra-only bring-up.
POLYGON_REST_ENABLED=0
POLYGON_WS_ENABLED=0
POLYGON_API_KEY_FILE=../../data/secrets/polygon_api_key
POLYGON_KEY_FILE=../../data/secrets/polygon_api_key
YFINANCE_ENABLED=1
YFINANCE_LIVE_BATCH_ENABLED=1
YFINANCE_LIVE_BATCH_TIMEOUT_S=6
YFINANCE_LIVE_BATCH_CHUNK_SIZE=128
YFINANCE_LIVE_BATCH_SIZE=
