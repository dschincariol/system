# Container images: set these to your approved tags.
TIMESCALE_IMAGE=
REDIS_IMAGE=
MINIO_IMAGE=
MINIO_CLIENT_IMAGE=
PYTHON_RUNTIME_IMAGE=python:3.11-slim
NODE_RUNTIME_IMAGE=node:20-bookworm-slim
APP_RUNTIME_IMAGE=trading-system/runtime:local
APP_OPERATOR_IMAGE=trading-system/operator:local

# External dependency credentials and ports.
TIMESCALE_DB=trading
TIMESCALE_USER=trading
TIMESCALE_PASSWORD=
TIMESCALE_PORT=5432

REDIS_PASSWORD=
REDIS_PORT=6379

MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
OBJECT_STORE_BUCKET=trading-artifacts
OBJECT_STORE_REGION=

# Application runtime/public ports.
APP_ENV=prod
ENGINE_MODE=safe
EXECUTION_MODE=safe
OPERATOR_MODE=safe
PROD_LOCK=1
ALLOW_TRAINING=0
TRADING_IMPORT_SMOKE_IMPORT_JOBS=0
TRADING_IMPORT_SMOKE_TIMEOUT_S=12.0
TRADING_STARTUP_HEALTH_FAIL_OPEN=0
TRADING_STARTUP_HEALTH_ASYNC_BIND=1
DASHBOARD_PUBLIC_PORT=8000
OPERATOR_PUBLIC_PORT=4001
DASHBOARD_API_TOKEN=
OPERATOR_API_TOKEN=
OPERATOR_ALLOWED_ORIGIN=http://127.0.0.1:8000

# Market data provider bootstrap. Leave disabled for first safe infra-only bring-up.
POLYGON_REST_ENABLED=0
POLYGON_WS_ENABLED=0
POLYGON_API_KEY=
POLYGON_KEY=
TRADIER_ENABLED=0
TRADIER_API_TOKEN=
OPTIONS_PROVIDER_CHAIN=
OPTIONS_SYMBOL_LIMIT=
OPTIONS_CRITICAL_SYMBOLS=DIA,SPY,QQQ,IWM

# Broker bootstrap. Keep sim/safe until paper validation passes.
BROKER_NAME=sim
BROKER=sim
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=

# Runtime dependency enforcement.
TIMESCALE_ENABLED=1
TIMESCALE_PRICES_ENABLED=1
PRICE_READ_BACKEND=auto
TELEMETRY_READ_BACKEND=auto
LIVE_CACHE_BACKEND=redis
PREFLIGHT_REQUIRE_TIMESCALE=1
PREFLIGHT_REQUIRE_REDIS=1
PREFLIGHT_REQUIRE_OBJECT_STORAGE=1
PREFLIGHT_EXTERNAL_TIMEOUT_S=2.0
AUTO_BOOT_DAEMONS=0
START_INGESTION_WITH_SERVER=1
