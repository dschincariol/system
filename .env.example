OPTIONS_GEX_RISK_FREE_RATE=0.045
OPTIONS_GEX_ZSCORE_OBS=5
OPTIONS_FLOW_ZSCORE_OBS=5
INGEST_FORM4_ENABLED=0
INGEST_CONGRESSIONAL_ENABLED=0
NEWS_EMBED_BACKEND=current
NEWS_EMBED_SENTENCE_MODEL=all-MiniLM-L6-v2
NEWS_EMBED_OPENAI_MODEL=text-embedding-3-small
NEWS_NOVELTY_LOOKBACK_DAYS=7
NEWS_NOVELTY_MAX_COMPARISONS=200
NEWS_FLOW_BATCH_SIZE=100
MACRO_PIT_MODE=auto
MACRO_VINTAGE_POLL_LOOKBACK_DAYS=14
