# Container images: set these to your approved tags.
TIMESCALE_IMAGE=
REDIS_IMAGE=
MINIO_IMAGE=
MINIO_CLIENT_IMAGE=
PYTHON_RUNTIME_IMAGE=python:3.11-slim
NODE_RUNTIME_IMAGE=node:20-bookworm-slim
APP_RUNTIME_IMAGE=trading-system/runtime:local
APP_OPERATOR_IMAGE=trading-system/operator:local

# External dependency credentials and ports.
TIMESCALE_DB=trading
TIMESCALE_USER=trading
TIMESCALE_PASSWORD=
TIMESCALE_PORT=5432
TRADING_BACKUP_ROOT=/var/backups/trading
TRADING_BACKUP_WAL_DIR=/var/backups/trading/wal

REDIS_PASSWORD=
REDIS_PORT=6379

MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
OBJECT_STORE_BUCKET=trading-artifacts
OBJECT_STORE_REGION=

# Application runtime/public ports.
APP_ENV=prod
ENGINE_MODE=safe
EXECUTION_MODE=safe
OPERATOR_MODE=safe
PROD_LOCK=1
ALLOW_TRAINING=0
TRADING_IMPORT_SMOKE_IMPORT_JOBS=0
TRADING_IMPORT_SMOKE_TIMEOUT_S=12.0
TRADING_STARTUP_HEALTH_FAIL_OPEN=0
TRADING_STARTUP_HEALTH_ASYNC_BIND=1
DASHBOARD_PUBLIC_PORT=8000
OPERATOR_PUBLIC_PORT=4001
DASHBOARD_API_TOKEN=
DASHBOARD_API_TOKEN_MIN_LENGTH=16
TS_API_ALLOW_LOCALHOST_MUTATIONS_WITHOUT_TOKEN=0
OPERATOR_API_TOKEN=
OPERATOR_ALLOWED_ORIGIN=http://127.0.0.1:8000
DATA_SOURCE_MASTER_KEY_FILE=../../data/.data_source_master_key

# Market data provider bootstrap. Leave disabled for first safe infra-only bring-up.
POLYGON_REST_ENABLED=0
POLYGON_WS_ENABLED=0
POLYGON_API_KEY=
POLYGON_KEY=
YFINANCE_ENABLED=1
TRADIER_ENABLED=0
TRADIER_API_TOKEN=
OPTIONS_PROVIDER_CHAIN=
OPTIONS_SYMBOL_LIMIT=
OPTIONS_CRITICAL_SYMBOLS=DIA,SPY,QQQ,IWM

# Broker bootstrap. Keep sim/safe until paper validation passes.
LIVE_BROKER=
BROKER_NAME=sim
BROKER=sim
BROKER_FAILOVER=sim
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
IBKR_HOST=
IBKR_PORT=
IBKR_CLIENT_ID=

# Runtime dependency enforcement.
TIMESCALE_ENABLED=1
TIMESCALE_PRICES_ENABLED=1
PRICE_READ_BACKEND=auto
TELEMETRY_READ_BACKEND=auto
LIVE_CACHE_BACKEND=redis
PREFLIGHT_REQUIRE_TIMESCALE=1
PREFLIGHT_REQUIRE_REDIS=1
PREFLIGHT_REQUIRE_OBJECT_STORAGE=1
PREFLIGHT_REQUIRE_BACKUP_EVIDENCE=1
BACKUP_EVIDENCE_PATH=/var/backups/trading/evidence/latest_backup_restore_evidence.json
BACKUP_EVIDENCE_BASE_BACKUP_MAX_AGE_S=93600
BACKUP_EVIDENCE_RPO_S=120
BACKUP_EVIDENCE_WAL_RPO_S=120
BACKUP_EVIDENCE_RESTORE_DRILL_MAX_AGE_S=7776000
BACKUP_EVIDENCE_RTO_S=1800
PREFLIGHT_EXTERNAL_TIMEOUT_S=2.0
AUTO_BOOT_DAEMONS=0
START_INGESTION_WITH_SERVER=0
MODEL_SCORING_ENABLED=0
AUTO_PIPELINE=0
AUTO_PIPELINE_INCLUDE_EXECUTION=0
AUTO_PIPELINE_INTERVAL_S=300
AUTO_PIPELINE_START_DELAY_S=90
MODEL_FEATURE_SNAPSHOT_SLEEP_S=60
MODEL_FEATURE_SNAPSHOT_BUCKET_SEC=60
INFERENCE_HEALTH_PROBE_ENABLED=1
INFERENCE_HEALTH_PROBE_SYMBOLS=AMD
INFERENCE_HEALTH_PROBE_INTERVAL_S=20
INFERENCE_HEALTH_PROBE_TIMEOUT_S=20
LIVE_TRADING_CONFIRM=0
LIVE_TRADING_REQUIRE_DASHBOARD_API_TOKEN=1
LIVE_TRADING_REQUIRE_CONFIRMATION=1
DISABLE_LIVE_EXECUTION=1
KILL_SWITCH_GLOBAL=1
