RULES_AUTO_RESUME=0
KILL_SWITCH_CACHE_TTL_S=30
KILL_SWITCH_CACHE_REPRIME_INTERVAL_S=10
KILL_SWITCH_CACHE_REPRIME_HEARTBEAT_S=10

# Offline/research/training compose profile. This profile is intentionally
# heavier and must point at an isolated offline datastore or restored clone.
OFFLINE_CPUS=16
OFFLINE_MEM_LIMIT=64g
OFFLINE_MEMSWAP_LIMIT=64g
OFFLINE_SHM_SIZE=16g
OFFLINE_APP_ENV=prod
OFFLINE_ENGINE_MODE=safe
OFFLINE_PROD_LOCK=0
OFFLINE_ALLOW_TRAINING=1
OFFLINE_DB_PATH=/app/offline-data
OFFLINE_TS_PG_DSN=
OFFLINE_MODEL_TRAIN_N_JOBS=8
OFFLINE_MODEL_TRAIN_MAX_N_JOBS=16
OFFLINE_META_LABEL_N_JOBS=8
OFFLINE_TSFRESH_N_JOBS=4
OFFLINE_TSFRESH_MAX_N_JOBS=16
OFFLINE_TSFRESH_SNAPSHOT_SYMBOL_LIMIT=5000
OFFLINE_TSFRESH_SNAPSHOT_MAX_SYMBOLS=5000
OFFLINE_TSFRESH_SNAPSHOT_BATCH_SIZE=250
OFFLINE_TSFRESH_SNAPSHOT_MAX_BATCH_SIZE=250
OFFLINE_TUNE_N_TRIALS=200
OFFLINE_TUNE_MAX_N_TRIALS=500
OFFLINE_RESOURCE_SCHEDULER_GLOBAL_MAX=8
OFFLINE_RESOURCE_SCHEDULER_TRAINING_MAX=4
OFFLINE_RESOURCE_SCHEDULER_REPLAY_MAX=2
OFFLINE_RESOURCE_SCHEDULER_BACKGROUND_MAX=4
