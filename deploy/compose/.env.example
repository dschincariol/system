# Broker bootstrap. Live identity defaults to IBKR; keep ENGINE_MODE and
# EXECUTION_MODE safe, DISABLE_LIVE_EXECUTION=1, and KILL_SWITCH_GLOBAL=1 until
# the live preflight/signoff sequence passes.
LIVE_BROKER=ibkr
BROKER_NAME=ibkr
BROKER=ibkr
BROKER_FAILOVER=ibkr
ALPACA_BASE_URL=https://api.alpaca.markets
ALPACA_KEY_ID_FILE=../../data/secrets/alpaca_key_id
ALPACA_SECRET_KEY_FILE=../../data/secrets/alpaca_secret_key
IBKR_HOST=host.docker.internal
IBKR_PORT=7497
IBKR_CLIENT_ID=42

