// Authorize the desktop user 'david' to start/stop/restart EXACTLY the two
// trading systemd units, and to run the dashboard-token reveal helper, with no
// password prompt.
//
// Keyed on subject.active (NOT subject.local): this desktop is reached over
// NoMachine/NX, whose sessions are seatless, so subject.local is false and a
// subject.local check would force a password prompt on every click. We scope
// strictly to user == "david", an active session, and the two unit names.
// Anything else returns NOT_HANDLED so normal admin policy still applies.
polkit.addRule(function(action, subject) {
    if (subject.user !== "david" || !subject.active) {
        return polkit.Result.NOT_HANDLED;
    }

    if (action.id === "org.freedesktop.systemd1.manage-units") {
        var unit = action.lookup("unit");
        if (unit === "trading-engine.service" || unit === "trading-operator.service") {
            return polkit.Result.YES;
        }
    }

    if (action.id === "org.freedesktop.policykit.exec") {
        var program = action.lookup("program");
        if (program === "/opt/trading/bin/trading-cred-show") {
            return polkit.Result.YES;
        }
    }

    return polkit.Result.NOT_HANDLED;
});
