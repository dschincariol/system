          "format": "table",
          "rawSql": "SELECT COALESCE(tags_json::jsonb->>'query_id', 'unknown') AS query_id,\n       MAX(value_num) AS total_time_ms,\n       MAX(NULLIF(value_text, '')) AS normalized_query\nFROM runtime_metrics\nWHERE metric = 'pg_stat_statements.total_time_ms'\n  AND $__timeFilter(to_timestamp(ts_ms / 1000.0))\nGROUP BY 1\nORDER BY 2 DESC\nLIMIT 10",
          "refId": "A"
        }
