# Sanitized deployment environment template.
# Copy to deploy/env/trading.env locally and fill values outside Git.

TRADING_ROOT=
TRADING_REPO=
TRADING_DATA=
TRADING_LOGS=
TRADING_BACKUPS=
PYTHON_VENV=
DB_PATH=/var/lib/trading
TRADING_LOCAL_LOG_MAX_BYTES=
TRADING_LOCAL_LOG_BACKUP_COUNT=
TRADING_LOCAL_LOG_MAX_AGE_DAYS=
HF_HOME=
SENTENCE_TRANSFORMERS_HOME=
ENV=prod
NODE_ENV=production
DASHBOARD_HOST=
DASHBOARD_PORT=
DASHBOARD_BASE=
# Trusted-LAN access: set TRADING_NETWORK_MODE=lan to default only
# DASHBOARD_HOST to 0.0.0.0. The operator sidecar stays loopback/internal by
# default and should be reached through the authenticated dashboard bridge at
# /operator/. A non-loopback dashboard bind requires DASHBOARD_API_TOKEN; in
# live/prod it ALSO requires the public-exposure acknowledgement
# (TRADING_PUBLIC_NETWORK_EXPOSURE_ACK + owner + reason). TRADING_LAN_IP only
# affects the LAN URL printed at startup. See docs/LAN_ACCESS.md. Keep these
# services off the public internet.
TRADING_NETWORK_MODE=
TRADING_LAN_IP=
DASHBOARD_API_TOKEN_FILE=/etc/trading/secrets/dashboard_api_token
DASHBOARD_API_TOKEN_MIN_LENGTH=32
PROD_PREFLIGHT_REQUIRED_CREDENTIALS=pg_password_app
LIVE_TRADING_REQUIRE_DASHBOARD_API_TOKEN=1
LIVE_TRADING_REQUIRE_CONFIRMATION=1
