# Sanitized staging prod-preflight harness template.
# Copy to deploy/env/staging-prod-preflight.env locally and fill values outside Git.

STAGING_PREFLIGHT_TARGET_ENV=staging
STAGING_PREFLIGHT_TARGET_ID=staging-postgres

# The harness requires Postgres runtime storage and refuses SQLite fallback.
TS_STORAGE_BACKEND=postgres
TS_PG_DSN=host=staging-postgres.example.internal port=5432 user=ts_app dbname=trading_staging sslmode=require
TS_PG_ROLE=app
TS_PG_PASSWORD=

# Keep staging preflight non-live unless a separate, intentional production
# confirmation is supplied on the harness command line.
APP_ENV=staging
ENV=staging
ENGINE_MODE=safe
EXECUTION_MODE=safe
OPERATOR_MODE=safe
PROD_LOCK=1
ALLOW_TRAINING=0
DISABLE_LIVE_EXECUTION=1
KILL_SWITCH_GLOBAL=1

# Dependency checks. Set staging endpoints and credentials outside Git.
PREFLIGHT_REQUIRE_TIMESCALE=1
PREFLIGHT_REQUIRE_REDIS=1
PREFLIGHT_REQUIRE_OBJECT_STORAGE=1
PREFLIGHT_REQUIRE_BACKUP_EVIDENCE=0
TIMESCALE_DSN=host=staging-postgres.example.internal port=5432 user=ts_app dbname=trading_staging sslmode=require
TIMESCALE_PRICES_DSN=host=staging-postgres.example.internal port=5432 user=ts_app dbname=trading_staging sslmode=require
LIVE_CACHE_REDIS_URL=redis://staging-redis.example.internal:6379/0
OBJECT_STORE_ENDPOINT=https://staging-minio.example.internal
OBJECT_STORE_BUCKET=trading-staging-artifacts
OBJECT_STORE_ACCESS_KEY=
OBJECT_STORE_SECRET_KEY=

# Runtime auth must be generated per staging environment.
DASHBOARD_API_TOKEN=
DASHBOARD_API_TOKEN_MIN_LENGTH=32

# Optional evidence policy if staging keeps backup/restore evidence.
BACKUP_EVIDENCE_PATH=
BACKUP_EVIDENCE_REQUIRE_SIGNATURE=0
BACKUP_EVIDENCE_HMAC_KEY_FILE=
