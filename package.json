{
  "name": "trading-engine-operator",
  "version": "1.0.0",
  "private": true,
  "description": "Trading Engine Operator Control Panel",
  "main": "boot/operator_server.js",
  "scripts": {
    "start": "node boot/operator_server.js",
    "start:operator": "node boot/operator_server.js",
    "start:engine": "python start_system.py",
    "check:syntax": "python tools/syntax_check_workspace.py",
    "lint:noops": "python tools/noop_guard.py",
    "test:py": "python -m pytest tests/ -v --tb=short",
    "test:news": "python tools/news_ingestion_selftest.py",
    "smoke:pipeline": "python tools/pipeline_smoke_test.py",
    "validate": "python tools/validate_repo.py",
    "validate:hygiene": "python tools/check_repo_artifact_hygiene.py --report",
    "check:ui": "node tools/run_ui_checks.mjs",
    "test:ui": "node tools/run_ui_checks.mjs --pytest",
    "validate:live": "python tools/validate_repo.py --live",
    "validate:deps": "python tools/validate_dependency_lock.py",
    "worktree:triage": "python tools/git_worktree_triage.py",
    "deps:ci": "npm ci",
    "deps:install": "npm install",
    "backup": "bash deploy/bin/backup_trading_db.sh",
    "upgrade": "bash deploy/bin/upgrade_trading_system.sh"
  },
  "engines": {
    "node": ">=20.17.0 <21",
    "npm": ">=10.0.0 <11"
  },
  "dependencies": {
    "express": "4.22.1",
    "sqlite3": "6.0.1",
    "ws": "8.20.0"
  }
}
