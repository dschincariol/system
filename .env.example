# Core runtime
ENV=dev
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000

# --- Trusted-LAN access (opt-in) ------------------------------------------
# The dashboard (:8000) binds to loopback by default (local-only), while the
# operator sidecar (:4001) stays loopback/internal and is reached through the
# dashboard /operator/ bridge. To reach the dashboard from another machine on a
# trusted LAN (e.g. a Windows desktop at http://192.168.0.165:8000), set:
#   TRADING_NETWORK_MODE=lan
# which defaults DASHBOARD_HOST to 0.0.0.0. The startup gate then REQUIRES
# DASHBOARD_API_TOKEN (a non-loopback bind without a token is rejected) -- set a
# strong token below. TRADING_LAN_IP is used only to print the LAN URL in
# startup logs; browser code never hard-codes it.
# See docs/LAN_ACCESS.md.
# TRADING_NETWORK_MODE=lan
# TRADING_LAN_IP=192.168.0.165
# Optional LAN performance tuning (defaults shown):
# DASHBOARD_GZIP_MIN_BYTES=1024
# DASHBOARD_STATIC_CACHE_MAX_AGE_S=60

# Generate a high-entropy value for production/live. Leaving this empty is
# accepted only for explicit safe local development with the localhost fallback
# flag below. Prefer DASHBOARD_API_TOKEN_FILE for local sim/prod-like boots.
DASHBOARD_API_TOKEN=
DASHBOARD_API_TOKEN_FILE=
DASHBOARD_API_TOKEN_MIN_LENGTH=16
OPERATOR_API_TOKEN_FILE=
TS_API_ALLOW_LOCALHOST_MUTATIONS_WITHOUT_TOKEN=1
LIVE_TRADING_REQUIRE_DASHBOARD_API_TOKEN=1
LIVE_TRADING_REQUIRE_CONFIRMATION=1
# Set this only in operator-controlled deployment configuration when live
# execution is intentionally being enabled. Empty examples fail closed.
LIVE_TRADING_CONFIRM=
# Emergency live-capital kill switch. Keep enabled unless live execution is
# intentionally being armed; unset and any value except 0/false/no/off block
# real broker routing and terminal live order intent creation.
DISABLE_LIVE_EXECUTION=1
# Initial live-capital hold. Keep this armed for live deployment validation
# until operator signoff and audited DB execution arming are complete.
KILL_SWITCH_GLOBAL=1
# Rules-owned halt auto-resume is explicit opt-in. Manual/operator holds use
# the confirmed operator clear workflow instead.
RULES_AUTO_RESUME=0
# Kill-switch Redis snapshots are bounded and fail closed when stale storage
# truth cannot be reloaded. The refresh daemon keeps this warmer than writes.
KILL_SWITCH_CACHE_TTL_S=30
KILL_SWITCH_CACHE_REPRIME_INTERVAL_S=10
KILL_SWITCH_CACHE_REPRIME_HEARTBEAT_S=10
# Runtime storage is Postgres. DB_PATH remains the local data root used by
# diagnostics, artifacts, and legacy identity. It is not a Postgres DSN.
# Production/supervised/live runtimes must set an absolute directory such as
# /var/lib/trading; relative paths are accepted only for explicit local dev/test.
# Launcher-loaded profiles normalize DB_PATH, TRADING_DATA, TRADING_LOGS, and
# SQLITE_LIVENESS_DB_PATH to absolute paths before strict runtime validation.
DB_PATH=/var/lib/trading
TS_PG_DSN=
TS_PG_SCHEMA=trading
TS_PG_POOL_TIMEOUT=5
TS_PG_POOL_MIN_SIZE=2
TS_PG_POOL_SIZE=4
# Valid values: default, relaxed. Empty/unset behaves as default and leaves
# Postgres synchronous_commit unchanged. Set to relaxed only for approved
# refetchable ingestion price/telemetry writes; invalid values fail production
# preflight/write-surface config, and order, broker, ledger, risk, audit, and
# capital-state writes never receive this tier.
TRADING_REFETCHABLE_PG_DURABILITY_TIER=default
INGESTION_TUNING_PROFILE=safe
INGESTION_TUNING_MAX_TOTAL_DB_CONNECTIONS=24
INGESTION_TUNING_MAX_BUFFERED_ROWS=1200000
# Optional production preflight ingestion soak evidence JSON. The PREFLIGHT_*
# name takes precedence; INGESTION_SOAK_JSON remains a compatibility alias.
PREFLIGHT_INGESTION_SOAK_JSON=
INGESTION_SOAK_JSON=
# Short in-process TTL for ingestion supervisor price/provider/source and
# child-heartbeat snapshots. Set 0 only for debugging cache behavior.
INGESTION_RUNTIME_SNAPSHOT_CACHE_TTL_S=1.0
# Horizontal ingestion sharding. Defaults keep single-shard behavior and the
# historical job/heartbeat names unchanged. For N supervisors, set count=N and
# give each supervisor a unique zero-based index. Multi-shard supervisors use
# shard-specific ingestion pid/stdout/stderr files and liveness rows.
INGESTION_SHARD_INDEX=0
INGESTION_SHARD_COUNT=1
INGESTION_CHILD_TS_PG_POOL_MIN_SIZE=1
INGESTION_CHILD_TS_PG_POOL_SIZE=2
INGESTION_CHILD_TIMESCALE_POOL_MAX_SIZE=2
INGESTION_CHILD_TIMESCALE_PRICES_POOL_MAX_SIZE=2
TS_REDIS_POOL_SIZE=16
TS_REDIS_CONNECT_TIMEOUT_S=0.25
TS_REDIS_SOCKET_TIMEOUT_S=0.25
REDIS_URL=
REDIS_PASSWORD_FILE=
DASHBOARD_STORAGE_REQUEST_TIMEOUT_S=0.5
DASHBOARD_STORAGE_STARTUP_TIMEOUT_S=2.0
TRADING_LOCAL_LOG_MAX_BYTES=52428800
TRADING_LOCAL_LOG_BACKUP_COUNT=5
TRADING_LOCAL_LOG_MAX_AGE_DAYS=14
TRADING_LOCAL_LOGROTATE_ENABLED=1
TRADING_LOCAL_LOGROTATE_INTERVAL_S=3600
TRADING_LOCAL_LOGROTATE_MAX_SIZE=50M
TRADING_LOCAL_LOGROTATE_ROTATE=5
TRADING_LOCAL_LOGROTATE_MAXAGE=14
PROD_LOCK=0
RUNTIME_WORKLOAD_PROFILE=live
ALLOW_TRAINING=1
RESOURCE_SCHEDULER_GLOBAL_MAX=8
RESOURCE_SCHEDULER_EXECUTION_MAX=0
RESOURCE_SCHEDULER_INFERENCE_MAX=2
RESOURCE_SCHEDULER_TRAINING_MAX=4
RESOURCE_SCHEDULER_REPLAY_MAX=2
RESOURCE_SCHEDULER_BACKGROUND_MAX=4
MODEL_TRAIN_N_JOBS=8
MODEL_TRAIN_MAX_N_JOBS=16
LGBM_N_JOBS=8
LGBM_RANKER_N_JOBS=8
XGB_N_JOBS=8
META_LABEL_N_JOBS=8
TSFRESH_N_JOBS=4
TSFRESH_MAX_N_JOBS=16
TSFRESH_SNAPSHOT_SYMBOL_LIMIT=5000
TSFRESH_SNAPSHOT_MAX_SYMBOLS=5000
TSFRESH_SNAPSHOT_BATCH_SIZE=250
TSFRESH_SNAPSHOT_MAX_BATCH_SIZE=250
TUNE_N_TRIALS=200
TUNE_MAX_N_TRIALS=500
TIMESCALE_ENABLED=0
# Host imports use host-resolvable names such as 127.0.0.1. Compose containers
# use service names through deploy/compose/docker-compose.stack.yml instead.
TS_PG_PASSWORD_FILE=
TIMESCALE_DSN=
TIMESCALE_SCHEMA=public
TIMESCALE_POOL_MIN_SIZE=1
TIMESCALE_POOL_MAX_SIZE=4
TIMESCALE_BATCH_SIZE=2000
TIMESCALE_FLUSH_INTERVAL_S=1.0
TIMESCALE_QUEUE_MAXSIZE=256
TIMESCALE_COPY_STAGING_ENABLED=1
TIMESCALE_COPY_STAGING_FALLBACK_ENABLED=1
TIMESCALE_RETRY_ATTEMPTS=5
TIMESCALE_RETRY_BASE_S=0.25
TIMESCALE_RETRY_MAX_S=5.0
TIMESCALE_BACKPRESSURE_TIMEOUT_S=5.0
TIMESCALE_START_TIMEOUT_S=5.0
TIMESCALE_CONNECT_TIMEOUT_S=5.0
TIMESCALE_LOCK_TIMEOUT_S=5.0
TIMESCALE_COMMAND_TIMEOUT_S=30.0
TIMESCALE_IDLE_IN_TXN_TIMEOUT_S=60.0
TIMESCALE_APPLICATION_NAME=trading-system
TIMESCALE_RETENTION_DAYS=0
TIMESCALE_COMPRESSION_AFTER_DAYS=0
TIMESCALE_TELEMETRY_MIRROR_ENABLED=0
TIMESCALE_TELEMETRY_MIRROR_POLL_INTERVAL_S=1.0
TIMESCALE_TELEMETRY_MIRROR_BATCH_SIZE=500
TIMESCALE_TELEMETRY_MIRROR_START_MODE=current
TIMESCALE_TELEMETRY_VALIDATION_ENABLED=0
TIMESCALE_TELEMETRY_VALIDATION_CACHE_TTL_S=15
TIMESCALE_TELEMETRY_VALIDATE_LOOKBACK_MINUTES=5
TIMESCALE_TELEMETRY_MAX_COUNT_DELTA=0
TIMESCALE_TELEMETRY_MAX_LAST_TS_LAG_MS=5000
TIMESCALE_TELEMETRY_REQUIRE_HEALTHY_MIRROR=1
TIMESCALE_TELEMETRY_REQUIRE_HEALTHY_TIMESCALE=1
# auto prefers validated Timescale reads when enabled and falls back through
# the runtime storage facade. Set sqlite only for explicit legacy/test reads.
TELEMETRY_READ_BACKEND=auto
TELEMETRY_READ_REQUIRE_VALIDATION=1
TELEMETRY_READ_FALLBACK_TO_SQLITE=1
TIMESCALE_PRICES_ENABLED=0
TIMESCALE_PRICES_DSN=
TIMESCALE_PRICES_SCHEMA=public
TIMESCALE_PRICES_POOL_MIN_SIZE=1
TIMESCALE_PRICES_POOL_MAX_SIZE=4
TIMESCALE_PRICES_CONNECT_TIMEOUT_S=5.0
TIMESCALE_PRICES_LOCK_TIMEOUT_S=5.0
TIMESCALE_PRICES_COMMAND_TIMEOUT_S=30.0
TIMESCALE_PRICES_IDLE_IN_TXN_TIMEOUT_S=60.0
TIMESCALE_PRICES_RETRY_ATTEMPTS=3
TIMESCALE_PRICES_RETRY_BASE_S=0.25
TIMESCALE_PRICES_RETRY_MAX_S=5.0
TIMESCALE_PRICES_CIRCUIT_FAILURE_THRESHOLD=3
TIMESCALE_PRICES_CIRCUIT_OPEN_S=5.0
TIMESCALE_PRICES_RETENTION_DAYS=0
TIMESCALE_PRICES_COMPRESSION_AFTER_DAYS=0
ASYNC_PRICE_WRITER_ENABLED=0
ASYNC_PRICE_WRITER_WORKERS=4
ASYNC_PRICE_WRITER_QUEUE_MAXSIZE=2048
ASYNC_PRICE_WRITER_BATCH_SIZE=256
ASYNC_PRICE_WRITER_FLUSH_INTERVAL_S=0.5
ASYNC_PRICE_WRITER_RETRY_ATTEMPTS=4
ASYNC_PRICE_WRITER_RETRY_BASE_S=0.25
ASYNC_PRICE_WRITER_RETRY_MAX_S=5.0
ASYNC_PRICE_WRITER_ENQUEUE_TIMEOUT_S=0.05
ASYNC_PRICE_WRITER_DEAD_LETTER_PATH=
# Optional durable spool override. Empty defaults to DB_PATH's directory, then
# TS_DATA_ROOT/default data root, with async_price_writer_spool.sqlite appended.
ASYNC_PRICE_WRITER_SPOOL_PATH=
ASYNC_PRICE_WRITER_SPOOL_MAX_BYTES=268435456
ASYNC_PRICE_WRITER_SPOOL_BUSY_TIMEOUT_MS=50
# NORMAL is the fast safe SQLite WAL default for re-fetchable market data.
# Set FULL or EXTRA explicitly when local spool fsync strength matters more
# than enqueue latency.
ASYNC_PRICE_WRITER_SPOOL_SYNCHRONOUS=NORMAL
PRICE_ROUTER_SQLITE_WRITE_ENABLED=1
PRICE_ROUTER_SQLITE_PRICES_ENABLED=1
PRICE_ROUTER_SQLITE_QUOTES_ENABLED=1
PRICE_ROUTER_SQLITE_RAW_ENABLED=1
PRICE_ROUTER_BLOCK_SYNC_SQLITE_IN_LIVE=1
PRICE_ROUTER_ALLOW_SYNC_SQLITE_IN_LIVE=0
FEATURE_STORE_SQLITE_WRITE_ENABLED=1
FEATURE_REGISTRY_CACHE_TTL_S=15
PRICE_ROUTER_REQUIRE_ASYNC_DURING_CUTOVER=1
# auto prefers validated Timescale price reads when enabled and falls back
# through the runtime storage facade. Set sqlite only for explicit legacy/test
# reads.
PRICE_READ_BACKEND=auto
PRICE_READ_REQUIRE_VALIDATION=1
PRICE_READ_FALLBACK_TO_SQLITE=1
PRICE_MIGRATION_VALIDATION_ENABLED=0
PRICE_MIGRATION_VALIDATION_CACHE_TTL_S=15
PRICE_MIGRATION_VALIDATE_LOOKBACK_MINUTES=5
PRICE_MIGRATION_MAX_COUNT_DELTA=0
PRICE_MIGRATION_MAX_LAST_TS_LAG_MS=5000
PRICE_MIGRATION_REQUIRE_HEALTHY_ASYNC_WRITER=1
PRICE_MIGRATION_REQUIRE_HEALTHY_PG_STORAGE=1
PRICE_MIGRATION_MAX_QUEUE_DEPTH=0
RUNTIME_METRICS_BUFFER_ENABLED=1
RUNTIME_METRICS_FLUSH_INTERVAL_S=1.0
RUNTIME_METRICS_FLUSH_JITTER_RATIO=0.5
RUNTIME_METRICS_BUFFER_MAX_BATCH=256
RUNTIME_METRICS_BUFFER_MAX_ROWS=4096
EVENT_LOG_BUFFER_ENABLED=1
EVENT_LOG_BUFFER_FLUSH_INTERVAL_S=0.5
EVENT_LOG_BUFFER_FLUSH_JITTER_RATIO=0.25
EVENT_LOG_BUFFER_MAX_BATCH=128
EVENT_LOG_BUFFER_MAX_ROWS=2048
TELEMETRY_APPEND_BUFFER_ENABLED=1
TELEMETRY_APPEND_BUFFER_FLUSH_INTERVAL_S=0.5
TELEMETRY_APPEND_BUFFER_FLUSH_JITTER_RATIO=0.25
TELEMETRY_APPEND_BUFFER_MAX_BATCH=128
TELEMETRY_APPEND_BUFFER_MAX_ROWS=4096
TELEMETRY_APPEND_BUFFER_SPOOL_PATH=
TELEMETRY_APPEND_BUFFER_SPOOL_MAX_BYTES=67108864
TELEMETRY_APPEND_BUFFER_SPOOL_BUSY_TIMEOUT_MS=50
TELEMETRY_APPEND_BUFFER_SPOOL_SYNCHRONOUS=NORMAL
RUNTIME_META_BEST_EFFORT_MIN_INTERVAL_S=2.0
RUNTIME_META_BEST_EFFORT_BUFFER_ENABLED=1
RUNTIME_META_BEST_EFFORT_BUFFER_FLUSH_INTERVAL_S=0.5
RUNTIME_META_BEST_EFFORT_BUFFER_FLUSH_JITTER_RATIO=0.5
RUNTIME_META_BEST_EFFORT_BUFFER_MAX_BATCH=64
RUNTIME_META_BEST_EFFORT_BUFFER_MAX_KEYS=512
TS_PG_LIVENESS_QUEUE_ENABLED=1
TS_PG_LIVENESS_FLUSH_INTERVAL_S=1.0
TS_PG_LIVENESS_FLUSH_JITTER_RATIO=0.5
TS_PG_LIVENESS_MIN_PERSIST_INTERVAL_S=0
TS_PG_LIVENESS_MAX_BATCH=64
# SQLITE_LIVENESS_* controls are for the isolated SQLite test backend and
# historical compatibility tests. Postgres runtime liveness persists through
# the main Postgres storage facade.
SQLITE_LIVENESS_QUEUE_ENABLED=1
SQLITE_LIVENESS_FLUSH_INTERVAL_S=0.5
SQLITE_LIVENESS_MAX_BATCH=128
SQLITE_LIVENESS_MIN_PERSIST_INTERVAL_S=2.0
SQLITE_LIVENESS_BUSY_TIMEOUT_MS=250
SQLITE_LIVENESS_CONNECT_TIMEOUT_S=0.25
SQLITE_LIVENESS_DB_ENABLED=1
SQLITE_LIVENESS_DB_PATH=
INGESTION_PIPELINE_HEALTH_MIN_INTERVAL_S=5.0
DATA_SOURCE_STATUS_BEST_EFFORT_MIN_INTERVAL_S=15.0
DATA_SOURCE_CONNECTION_TEST_MIN_INTERVAL_S=2.0
IPC_CHANNEL_STATE_BEST_EFFORT_MIN_INTERVAL_S=2.0
ENGINE_MODE=safe
EXECUTION_MODE=safe
OPERATOR_MODE=local
# Live broker identity is explicit even when ENGINE_MODE remains safe. Real
# execution is still blocked by mode, confirmation, kill-switch, credential,
# pre-live reconciliation, and live execution gates until all live signoffs pass.
LIVE_BROKER=ibkr
BROKER_NAME=ibkr
BROKER=ibkr
BROKER_FAILOVER=ibkr
# Required in live mode. Empty values fail live preflight so an operator must
# explicitly choose observe_only, cancel_only, flatten_positions, or
# cancel_and_flatten before real capital is armed.
BROKER_SHUTDOWN_POLICY=
BROKER_SHUTDOWN_TIMEOUT_S=10
# Required only for shutdown/emergency policies that flatten positions.
BROKER_SHUTDOWN_FLATTEN_MAX_ABS_QTY_PER_SYMBOL=
BROKER_SHUTDOWN_FLATTEN_MAX_TOTAL_ABS_QTY=

# Startup / validation defaults
TRADING_STARTUP_HEALTH_TIMEOUT_S=45
TRADING_STARTUP_HEALTH_FAIL_OPEN=0
TRADING_STARTUP_HEALTH_ASYNC_BIND=1
PREFLIGHT_EXTERNAL_TIMEOUT_S=2.0
TRADING_CLOCK_MAX_SKEW_MS=2000
TRADING_CLOCK_REQUIRED_SOURCES=system_or_https
TRADING_CLOCK_HTTPS_TIME_URLS=https://www.google.com/generate_204,https://www.cloudflare.com/cdn-cgi/trace
TRADING_CLOCK_REQUIRED_TIMEZONE=UTC
TRADING_CLOCK_CHECK_TIMEOUT_S=1.5
PREFLIGHT_REQUIRE_TIMESCALE=0
PREFLIGHT_REQUIRE_REDIS=0
PREFLIGHT_REQUIRE_OBJECT_STORAGE=0
PREFLIGHT_REQUIRE_BACKUP_EVIDENCE=0
CACHE_CODEC_ALLOW_JSON_FALLBACK=0
CACHE_CODEC_REQUIRE_MSGPACK=0
# Optional pg_wal disk-risk inspection. Required production preflight modes run
# the DB-backed query automatically; set PREFLIGHT_QUERY_PG_WAL_RISK=1 to run it
# in safe/non-required modes. TS_PG_WAL_DIR defaults to PGDATA/pg_wal, then
# /var/lib/postgresql/data/pg_wal. Timeout falls back to PREFLIGHT_EXTERNAL_TIMEOUT_S.
TS_PG_WAL_DIR=
PREFLIGHT_QUERY_PG_WAL_RISK=0
PREFLIGHT_PG_WAL_RISK_TIMEOUT_S=
BACKUP_EVIDENCE_PATH=/var/backups/trading/evidence/latest_backup_restore_evidence.json
BACKUP_EVIDENCE_BASE_BACKUP_MAX_AGE_S=93600
BACKUP_EVIDENCE_RPO_S=120
BACKUP_EVIDENCE_RESTORE_DRILL_MAX_AGE_S=7776000
BACKUP_EVIDENCE_RTO_S=1800
BACKUP_EVIDENCE_SIGNATURE_MAX_AGE_S=120
BACKUP_EVIDENCE_REQUIRE_SIGNATURE=1
# Systemd production hosts should provision this through the encrypted
# credential named backup_evidence_hmac_key. Compose uses the *_FILE value
# below through a Docker secret. Direct file paths must point to a readable
# service-owned/root-owned 0600 file; group-readable files fail strict runtime.
BACKUP_EVIDENCE_HMAC_KEY_SECRET=backup_evidence_hmac_key
BACKUP_EVIDENCE_HMAC_KEY_FILE=
TS_BACKUP_EVIDENCE_LOCK_TIMEOUT_S=30
TS_BACKUP_EVIDENCE_BASE_BACKUP_TIMEOUT_S=7200
TS_BACKUP_EVIDENCE_WAL_SWITCH_TIMEOUT_S=30
TS_BACKUP_EVIDENCE_WAL_ARCHIVER_STATS_TIMEOUT_S=30
TS_BACKUP_EVIDENCE_RESTORE_DRILL_TIMEOUT_S=3600
TS_BACKUP_EVIDENCE_SIGNATURE_TIMEOUT_S=30
TS_BACKUP_EVIDENCE_PUBLISH_TIMEOUT_S=30
SUPERVISOR_ENABLED=1
SUPERVISOR_TICK_S=2
AUTO_BOOT_DAEMONS=0
AUTO_BOOT_TARGETS=
AUTO_PIPELINE=0
AUTO_PIPELINE_INCLUDE_EXECUTION=0
EXEC_DEGRADE_BLOCK=1
EXEC_DEGRADE_WARN_COST_PCT=0.25
EXEC_DEGRADE_CRIT_COST_PCT=0.50
EPE_EQUITY_SESSION_ENFORCE=1
EQUITY_RTH_OPEN_HOUR_ET=9
EQUITY_RTH_OPEN_MIN_ET=30
EQUITY_RTH_CLOSE_HOUR_ET=16
EQUITY_RTH_CLOSE_MIN_ET=0
EQUITY_HALFDAY_CLOSE_HOUR_ET=13
EQUITY_HALFDAY_CLOSE_MIN_ET=0
EQUITY_MARKET_HOLIDAYS_JSON=
EQUITY_MARKET_HALFDAYS_JSON=
EQUITY_NEAR_CLOSE_BIAS_MIN=10
EQUITY_SESSION_UNKNOWN_YEAR_POLICY=open_rth

# Live-capital risk gates. Strict live mode fails prod preflight unless these
# hard-block thresholds are explicitly set above zero. Leave the acceptance
# override off unless a documented risk review has accepted the disabled gate.
PORTFOLIO_NOTIONAL_BACKSTOP=1
PORTFOLIO_BACKSTOP_MAX_GROSS=1.00
PORTFOLIO_BACKSTOP_MAX_NET=0.60
PORTFOLIO_RISK_MC_VAR_95_BLOCK=
PORTFOLIO_RISK_MC_VAR_99_BLOCK=
PORTFOLIO_RISK_MC_CVAR_95_BLOCK=
PORTFOLIO_RISK_MC_CVAR_99_BLOCK=
PORTFOLIO_RISK_MC_DRAWDOWN_P95_BLOCK=
PORTFOLIO_RISK_MC_WORST_DRAWDOWN_BLOCK=
PORTFOLIO_RISK_MC_REQUIRED_IN_LIVE=1
PORTFOLIO_RISK_MC_MAX_AGE_S=900
MC_SIMULATION_METHOD=gaussian
MC_STUDENT_T_DOF=6.0
MC_STUDENT_T_ESTIMATE_DOF=1
MC_STUDENT_T_MIN_DOF=3.0
MC_STUDENT_T_MAX_DOF=50.0
MC_HISTORICAL_MIN_OBS=60
MC_HISTORICAL_WINDOW=240
MC_EVT_CVAR_ENABLED=0
MC_EVT_THRESHOLD_Q=0.10
MC_EVT_MIN_TAIL=20
MC_RANDOM_SEED=
VAR_BACKTEST_STEP_MS=86400000
VAR_BACKTEST_MAX_FORECASTS=100
VAR_BACKTEST_ROLLING_WINDOW=250
RISK_VAR_BACKTEST_EVIDENCE_STALE_MS=1209600000
PORTFOLIO_RISK_VOL_HARD_BLOCK=
# Canonical risk covariance used by portfolio vol, correlation clusters,
# Monte Carlo inputs, and strategy risk helpers. Default shrinkage is
# Ledoit-Wolf when at least RISK_COVARIANCE_MIN_OBS aligned returns exist;
# otherwise the estimator records an explicit fallback reason.
RISK_COVARIANCE_METHOD=ledoit_wolf
RISK_COVARIANCE_MIN_OBS=60
RISK_COVARIANCE_FALLBACK=sample
RISK_COVARIANCE_RMT_ENABLED=0
RISK_COVARIANCE_RMT_MIN_ASSETS=12
RISK_COVARIANCE_RMT_DETONE=0
# Canonical one-day volatility forecast resolver for Monte Carlo, portfolio
# vol targeting, and per-symbol vol caps. Valid sources: trailing, har/har_rv,
# garch, egarch, gjr_garch, blend. GARCH-family fits require the optional
# Python extra `trading-system[volatility]` and GARCH_VOL_USE_ARCH=1; otherwise
# the refit job persists a deterministic EWMA/trailing fallback with diagnostics.
VOL_FORECAST_SOURCE=trailing
VOL_FORECAST_BLEND_WEIGHTS=trailing=0.34,har_rv=0.33,garch=0.33
HAR_RV_MIN_HISTORY=60
HAR_RV_HISTORY_DAYS=756
HAR_RV_TRAILING_DAYS=20
HAR_RV_FORECAST_MAX_AGE_DAYS=7
GARCH_VOL_USE_ARCH=0
GARCH_VOL_MODEL_TYPE=garch
GARCH_VOL_DISTRIBUTION=normal
GARCH_VOL_MIN_HISTORY=120
GARCH_VOL_HISTORY_DAYS=756
GARCH_VOL_FORECAST_MAX_AGE_DAYS=7
GARCH_VOL_HORIZON_DAYS=1
GARCH_VOL_EWMA_LAMBDA=0.94
GARCH_VOL_SYMBOL_LIMIT=5000
# Scope the default-off alert execution-cost filter after
# ALERT_USE_EXEC_COST_FILTER=1. Empty means all asset classes; non-empty
# comma-separated entries are upper-cased and matched against
# asset_class_for_symbol() values (EQUITY, CRYPTO, COMMODITY, FUTURES, OPTION,
# FX, RATES, UNKNOWN). Out-of-scope symbols skip cost adjustment/rejection.
ALERT_EXEC_COST_FILTER_ASSET_CLASSES=
PORTFOLIO_RISK_USE_EQUITY_LEVERAGE_CAPS=1
EQUITY_LEVERAGE_MODE=cash
EQUITY_LEVERAGE_CAPS_JSON=
KILL_SWITCH_MODEL_MAX_DRAWDOWN=
KILL_SWITCH_MODEL_MAX_CONSECUTIVE_LOSSES=
KILL_SWITCH_MAX_EQUITY_AGE_S=300
KILL_SWITCH_DAILY_EQUITY_MIN_POINTS=2
KILL_SWITCH_ROLLING_EQUITY_MIN_POINTS=5
KILL_SWITCH_VAR_EQUITY_MIN_POINTS=31
DRAWDOWN_MAX_EQUITY_AGE_S=300
LIVE_RISK_THRESHOLD_ACCEPTANCE_OVERRIDE=0
LIVE_RISK_THRESHOLD_ACCEPTANCE_ID=
LIVE_RISK_THRESHOLD_ACCEPTANCE_OWNER=
LIVE_RISK_THRESHOLD_ACCEPTANCE_REASON=

# Crypto live trading remains disabled unless explicitly owner-approved.
CRYPTO_LIVE_TRADING_ENABLED=0
CRYPTO_NOTIONAL_CAP_USD=10000

# FX live trading remains disabled unless explicitly owner-approved.
FX_LIVE_TRADING_ENABLED=0

# Provider toggles
POLL_PRICES_PROVIDER_MAX_WORKERS=3
POLL_PRICES_PROVIDER_TIMEOUT_S=30
IBKR_ENABLED=0
POLYGON_REST_ENABLED=0
POLYGON_WS_ENABLED=0
YFINANCE_ENABLED=1
YFINANCE_LIVE_BATCH_ENABLED=1
YFINANCE_LIVE_BATCH_TIMEOUT_S=6
YFINANCE_LIVE_BATCH_CHUNK_SIZE=128
YFINANCE_LIVE_BATCH_SIZE=
YFINANCE_LIVE_FALLBACK_SYMBOL_LIMIT=64
YFINANCE_LIVE_MAX_WORKERS=12
