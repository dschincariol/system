          "rawSql": "SELECT to_timestamp(ts_ms / 1000.0) AS \"time\", metric, value_num\nFROM runtime_metrics\nWHERE metric IN ('pgbouncer.pool.cl_active','pgbouncer.pool.cl_waiting','pgbouncer.pool.sv_active','pgbouncer.pool.sv_idle')\n  AND $__timeFilter(to_timestamp(ts_ms / 1000.0))\nORDER BY 1",
